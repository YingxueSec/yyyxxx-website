---
import Layout from '../../layouts/Layout.astro';

const pageConfig = {
  diaryTitle: '温柔小🐿&暴躁小🐒的恋爱日记📒',
  introQuote: '世间所有的相遇，都是久别重逢。',
  togetherSince: '2024-05-01',
  introSummary: '从我去潍坊见你的 2024 年 5 月，到后来的每一次重逢，下面每一页都是真实发生过的我们。',
  chapters: [
    {
      icon: '🌧️',
      date: '2024年5月',
      title: '初识',
      paragraphs: [
        '五月的风里裹着一场小雨，我去潍坊见你，你买了两杯霸王茶姬，站在那里等我。',
        '出租车上我问你紧张吗，你说不紧张。可是我紧张得不行，心跳快得像要溢出来。',
        '去泰华城吃了饭，一起看了《维和特工队》，灯光暗下来的时候，好像整个世界只剩我们两个人。',
        '临走你说要送我东西，结果又没给我。哼，欠我的，记着呢 🫣'
      ]
    },
    {
      icon: '🎁',
      date: '2024年7月',
      title: '从潍坊寄来的夏天',
      paragraphs: [
        '七月的时候，你从潍坊给我往北京寄来了一份礼物。',
        '包裹打开的那一刻，像是把一整个夏天都轻轻递到了我手里：有小鸡毛五月，有你画的油画棒，有纸风筝，有药，还有许多说不完的小心意。',
        '那些东西被你认真放进盒子里，也把很多很多的爱，一起寄到了我身边。'
      ]
    },
    {
      icon: '🚇',
      date: '2024年10月',
      title: '北京重逢',
      paragraphs: [
        '你来北京了。',
        '地铁站人来人往，可我一眼就看到了你。',
        '什么话都没说，只是紧紧地抱了抱。',
        '那一刻，所有的等待都有了意义 🤗'
      ]
    },
    {
      icon: '🍢',
      date: '来北京后',
      title: '距离近了一点点',
      paragraphs: [
        '你九月刚开始读博士，后来终于来到了北京。那天我下班早了些，我们临时起意去撸串。',
        '烟火气弥漫的小桌前，忽然觉得，我们之间的距离好像近了好多。',
        '那天的串很香，但更让人心动的，是那份说走就走的默契 😄'
      ]
    },
    {
      icon: '🍳',
      date: '2024年10月7日',
      title: '小宋师傅开课啦',
      paragraphs: [
        '你开始教我做菜，认认真真地传授“小宋师傅心经”。',
        '先放油，然后放肉，炒熟放葱姜蒜，闻到香味，放菜品，然后放生抽酱油醋，菜品熟了就出锅。',
        '简单的几句话，却是你把生活的温柔，一点一点揉进了烟火里 🥘'
      ],
      quoteIndex: 1
    },
    {
      icon: '🥟',
      date: '2024年之后',
      title: '在北京的日常',
      paragraphs: [
        '你来北京后我们经常见面，一起吃遍大街小巷。',
        '没有什么轰轰烈烈的仪式感，不过是两个人一起干饭，一起走路，一起笑。',
        '可这些平凡的日子，才是最快乐的时光。'
      ]
    },
    {
      icon: '🎆',
      date: '2025年1月1日',
      title: '我们的第一个元旦',
      paragraphs: [
        '新年的第一天，我们做了好多好吃的。',
        '满满一桌子菜，我拍了照发到同事群里炫耀：“看！这是我们的元旦！”',
        '哈哈哈，就是想让全世界都知道我有多幸福 ✨'
      ]
    },
    {
      icon: '🎂',
      date: '2025年农历正月十一',
      title: '第一个生日',
      paragraphs: [
        '在一起后的第一个生日（你过生日那天），我下班后为你张罗了一桌好菜，还有蛋糕。',
        '烛光摇曳的时候，我看着你许愿，也在心里偷偷许了一个关于我们的愿。',
        '能陪你过这个生日，是我那天最开心的事，不是因为蛋糕，是因为你在身边 🎁'
      ]
    },
    {
      icon: '🕯️',
      date: '2025年9月',
      title: '你为我点亮的生日',
      paragraphs: [
        '九月轮到我过生日，那天你来到家里，为我做了一桌很丰盛的晚餐。',
        '灯光落在热腾腾的饭菜上，也落在你忙前忙后的身影里，我忽然觉得，生日最好的仪式感，就是有人把你认真放在心上。',
        '我们一起吃了蛋糕，吹了蜡烛，许了愿，也拍下了很美好的照片。后来每次想起那一天，心里都会亮一下。'
      ]
    },
    {
      icon: '🌊',
      date: '2025年',
      title: '分分合合',
      paragraphs: [
        '这一年我们吵过、闹过、哭过、笑过。',
        '分分合合之间，却也更加笃定：兜兜转转，还是你。',
        '很充实，很真实，嘿嘿嘿 💕'
      ]
    },
    {
      icon: '🎂',
      date: '2026年',
      title: '又一个生日',
      paragraphs: [
        '今年你过生日那天，我下班后我们去了海底捞，提着蛋糕去，提着蛋糕回。',
        '火锅的热气蒸腾，模糊了你的脸，却模糊不了我心里的甜。',
        '你又长大了一岁，而我还是在你身边，真好 🫶'
      ]
    },
    {
      icon: '🌸',
      date: '2026年3月',
      title: '颐和园的春风',
      paragraphs: [
        '三月的时候，我们去了颐和园。',
        '湖边的风吹过来，带着一点春天刚醒来的温柔，我们慢慢走着，好像连时间都变得轻了。',
        '晚上回来又去吃了芈重山火锅，热气和辣意一起涌上来，辣得不行，却也热热闹闹地把那一天留在了心里。'
      ]
    },
    {
      icon: '✨',
      date: '还有很多很多',
      title: '没有写完的美好',
      paragraphs: [
        '其实还有很多美好，没有来得及被写进这一页。',
        '有些是一起走过的路，有些是深夜说过的话，有些是吃到好吃的东西时忍不住看向彼此的笑，也有些只是很普通的一天，却因为身边是你，就变得值得记住。',
        '也许日记永远写不完，但没关系。那些没有被记录下来的瞬间，也都在我们心里，好好地发着光。'
      ]
    }
  ],
  endingQuote: '故事还在继续，而最好的篇章，永远是下一页。'
};

const pageTitle = pageConfig.diaryTitle;
const pageDescription = '给晓玉的真实恋爱时间线，记录温柔小🐿和暴躁小🐒从 2024 到 2026 的日记。';
---

<Layout title={pageTitle} description={pageDescription} noindex={true}>
  <main class="love-root" data-since={pageConfig.togetherSince}>
    <div class="progress-track" aria-hidden="true">
      <span id="scroll-progress"></span>
    </div>

    <div class="aurora" aria-hidden="true">
      <span class="blob b1"></span>
      <span class="blob b2"></span>
      <span class="blob b3"></span>
    </div>
    <div class="cursor-glow" aria-hidden="true"></div>
    <div class="floating-hearts" aria-hidden="true"></div>
    <div class="sparkle-rain" aria-hidden="true"></div>

    <section class="hero panel reveal">
      <p class="eyebrow">/loveyuyyuyu/</p>
      <h1 class="title">{pageConfig.diaryTitle}</h1>
      <blockquote class="main-quote">“{pageConfig.introQuote}”</blockquote>
      <p class="subtitle">{pageConfig.introSummary}</p>

      <div class="story-meta" aria-label="故事信息">
        <span>真实记录</span>
        <span>{pageConfig.chapters.length} 个章节</span>
        <span>2024 → 2026</span>
      </div>

      <div class="together-panel" aria-live="polite">
        <p class="together-label">在一起时间从 2024年5月1日 开始</p>
        <p id="together-counter" class="together-counter">加载中...</p>
        <p id="next-anniversary" class="next-anniversary">计算中...</p>
      </div>

      <nav class="chapter-nav" aria-label="章节速览">
        {pageConfig.chapters.map((chapter, idx) => (
          <a href={`#chapter-${idx + 1}`} class="chapter-link">
            {chapter.icon} {chapter.date}
          </a>
        ))}
      </nav>

      <div class="hero-actions">
        <button id="burst-btn" class="btn solid" type="button">点亮这一页</button>
        <a class="btn ghost" href="#timeline">查看时间线</a>
      </div>
    </section>

    <section id="timeline" class="panel timeline reveal">
      <h2>恋爱时间线</h2>
      <ol class="diary-list">
        {pageConfig.chapters.map((chapter, idx) => (
          <li class="diary-item" data-index={idx} id={`chapter-${idx + 1}`}>
            <p class="diary-head">
              <span class="date-chip">{chapter.icon} {chapter.date}</span>
            </p>
            <h3>{chapter.title}</h3>
            {chapter.paragraphs.map((text, textIndex) =>
              chapter.quoteIndex === textIndex ? (
                <blockquote class="entry-quote">{text}</blockquote>
              ) : (
                <p>{text}</p>
              )
            )}
          </li>
        ))}
      </ol>
    </section>

    <section class="panel ending reveal">
      <p class="ending-text">“{pageConfig.endingQuote}” 🐿️❤️🐒</p>
    </section>

    <section id="mini-game" class="panel game-panel reveal">
      <div>
        <h2>爱心接接乐</h2>
        <p>想放松一下就玩一局：移动底部小篮子接住掉落爱心，30 秒结束，支持鼠标和触摸。</p>
      </div>

      <div class="game-status">
        <p>得分：<strong id="game-score">0</strong></p>
        <p>剩余：<strong id="game-time">30</strong>s</p>
      </div>

      <canvas id="heart-game" width="360" height="500" aria-label="爱心接接乐游戏画布"></canvas>

      <div class="game-actions">
        <button id="game-start" class="btn solid" type="button">开始游戏</button>
        <p id="game-result" class="game-result">准备好就开始吧。</p>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const root = document.querySelector('.love-root');
      if (!root) return;

      const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealEls = Array.from(document.querySelectorAll('.reveal'));
      const heartLayer = document.querySelector('.floating-hearts');
      const sparkleLayer = document.querySelector('.sparkle-rain');
      const cursorGlow = document.querySelector('.cursor-glow');
      const burstBtn = document.getElementById('burst-btn');
      const diaryCards = Array.from(document.querySelectorAll('.diary-item'));
      const scrollProgress = document.getElementById('scroll-progress');
      const togetherCounter = document.getElementById('together-counter');
      const nextAnniversary = document.getElementById('next-anniversary');
      const sinceRaw = root.getAttribute('data-since') || '2024-05-01';
      const togetherSince = new Date(`${sinceRaw}T00:00:00+08:00`);

      const revealAll = () => revealEls.forEach((el, idx) => {
        window.setTimeout(() => el.classList.add('is-visible'), idx * 100);
      });

      if (!prefersReduce && 'IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });
        revealEls.forEach((el) => observer.observe(el));
      } else {
        revealAll();
      }

      const pad = (num) => String(num).padStart(2, '0');
      const updateTogether = () => {
        const now = new Date();
        const diff = Math.max(0, now.getTime() - togetherSince.getTime());
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
        const minutes = Math.floor((diff / (1000 * 60)) % 60);
        const seconds = Math.floor((diff / 1000) % 60);

        if (togetherCounter) {
          togetherCounter.textContent = `${days} 天 ${pad(hours)} 小时 ${pad(minutes)} 分 ${pad(seconds)} 秒`;
        }

        const nextYear = (now.getMonth() > 4 || (now.getMonth() === 4 && now.getDate() > 1))
          ? now.getFullYear() + 1
          : now.getFullYear();
        const nextDate = new Date(`${nextYear}-05-01T00:00:00+08:00`);
        const leftDays = Math.ceil((nextDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24));

        if (nextAnniversary) {
          nextAnniversary.textContent = `距离 ${nextYear} 年 5 月 1 日纪念日还有 ${Math.max(leftDays, 0)} 天`;
        }
      };

      updateTogether();
      window.setInterval(updateTogether, 1000);

      const burstHearts = (x, y, count = 14) => {
        if (!heartLayer) return;

        for (let i = 0; i < count; i += 1) {
          const heart = document.createElement('span');
          heart.className = 'burst-heart';
          const angle = (Math.PI * 2 * i) / count;
          const distance = 24 + Math.random() * 88;
          heart.style.setProperty('--tx', `${Math.cos(angle) * distance}px`);
          heart.style.setProperty('--ty', `${Math.sin(angle) * distance}px`);
          heart.style.left = `${x}px`;
          heart.style.top = `${y}px`;
          heart.textContent = Math.random() > 0.5 ? '❤' : '💗';
          heartLayer.appendChild(heart);
          window.setTimeout(() => heart.remove(), 1200);
        }
      };

      if (burstBtn) {
        burstBtn.addEventListener('click', (event) => {
          const rect = event.currentTarget.getBoundingClientRect();
          burstHearts(rect.left + rect.width / 2, rect.top + rect.height / 2, 18);
        });
      }

      diaryCards.forEach((card, idx) => {
        card.style.setProperty('--delay', `${idx * 70}ms`);

        card.addEventListener('pointermove', (event) => {
          if (prefersReduce) return;
          const rect = card.getBoundingClientRect();
          const px = ((event.clientX - rect.left) / rect.width) - 0.5;
          const py = ((event.clientY - rect.top) / rect.height) - 0.5;
          card.style.setProperty('--rx', `${(-py * 6).toFixed(2)}deg`);
          card.style.setProperty('--ry', `${(px * 8).toFixed(2)}deg`);
        });

        card.addEventListener('pointerleave', () => {
          card.style.setProperty('--rx', '0deg');
          card.style.setProperty('--ry', '0deg');
        });

        card.addEventListener('click', (event) => {
          const rect = event.currentTarget.getBoundingClientRect();
          burstHearts(rect.left + rect.width / 2, rect.top + rect.height / 2, 10);
          card.classList.add('pop');
          window.setTimeout(() => card.classList.remove('pop'), 240);
        });
      });

      if (heartLayer) {
        const heartCount = window.innerWidth < 600 ? 18 : 32;
        for (let i = 0; i < heartCount; i += 1) {
          const floatHeart = document.createElement('span');
          floatHeart.className = 'float-heart';
          floatHeart.textContent = Math.random() > 0.5 ? '❤' : '♡';
          floatHeart.style.left = `${Math.random() * 100}%`;
          floatHeart.style.animationDelay = `${Math.random() * 10}s`;
          floatHeart.style.animationDuration = `${9 + Math.random() * 12}s`;
          heartLayer.appendChild(floatHeart);
        }
      }

      if (sparkleLayer && !prefersReduce) {
        const sparkleCount = window.innerWidth < 600 ? 22 : 40;
        for (let i = 0; i < sparkleCount; i += 1) {
          const star = document.createElement('span');
          star.className = 'star';
          star.style.left = `${Math.random() * 100}%`;
          star.style.top = `${Math.random() * 100}%`;
          star.style.animationDelay = `${Math.random() * 6}s`;
          star.style.animationDuration = `${2.4 + Math.random() * 3.6}s`;
          sparkleLayer.appendChild(star);
        }
      }

      if (cursorGlow && !prefersReduce) {
        window.addEventListener('pointermove', (event) => {
          cursorGlow.style.left = `${event.clientX}px`;
          cursorGlow.style.top = `${event.clientY}px`;
          cursorGlow.style.opacity = '1';
        });

        window.addEventListener('pointerdown', () => {
          cursorGlow.classList.add('active');
          window.setTimeout(() => cursorGlow.classList.remove('active'), 180);
        });
      }

      if (scrollProgress) {
        const updateProgress = () => {
          const maxScroll = Math.max(document.documentElement.scrollHeight - window.innerHeight, 1);
          const ratio = Math.min(1, Math.max(0, window.scrollY / maxScroll));
          scrollProgress.style.width = `${ratio * 100}%`;
        };

        updateProgress();
        window.addEventListener('scroll', updateProgress, { passive: true });
        window.addEventListener('resize', updateProgress);
      }

      const emitGameSpark = (x, y, count = 8) => {
        if (!heartLayer) return;

        for (let i = 0; i < count; i += 1) {
          const spark = document.createElement('span');
          spark.className = 'game-spark';
          spark.style.left = `${x}px`;
          spark.style.top = `${y}px`;
          spark.style.setProperty('--vx', `${(Math.random() - 0.5) * 120}px`);
          spark.style.setProperty('--vy', `${-30 - Math.random() * 90}px`);
          spark.style.setProperty('--scale', `${0.6 + Math.random() * 0.8}`);
          heartLayer.appendChild(spark);
          window.setTimeout(() => spark.remove(), 800);
        }
      };

      const canvas = document.getElementById('heart-game');
      const scoreEl = document.getElementById('game-score');
      const timeEl = document.getElementById('game-time');
      const startBtn = document.getElementById('game-start');
      const resultEl = document.getElementById('game-result');

      if (!(canvas instanceof HTMLCanvasElement)) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const state = {
        running: false,
        score: 0,
        timeLeft: 30,
        basketX: 140,
        basketW: 86,
        basketH: 22,
        hearts: [],
        spawnClock: 0,
        secondClock: 0,
        lastTs: performance.now(),
        rafId: 0
      };

      const palette = ['#ff6b8a', '#ff8fab', '#ff4d6d', '#ffc2d1'];

      const drawHeart = (x, y, size, color) => {
        ctx.save();
        ctx.translate(x, y);
        ctx.scale(size / 20, size / 20);
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.moveTo(10, 18);
        ctx.bezierCurveTo(10, 18, 1, 12, 1, 7.5);
        ctx.bezierCurveTo(1, 4, 3.5, 1, 7, 1);
        ctx.bezierCurveTo(9, 1, 10, 2.2, 10, 2.2);
        ctx.bezierCurveTo(10, 2.2, 11, 1, 13, 1);
        ctx.bezierCurveTo(16.5, 1, 19, 4, 19, 7.5);
        ctx.bezierCurveTo(19, 12, 10, 18, 10, 18);
        ctx.fill();
        ctx.restore();
      };

      const resetGame = () => {
        state.score = 0;
        state.timeLeft = 30;
        state.hearts = [];
        state.spawnClock = 0;
        state.secondClock = 0;
        state.basketX = (canvas.width - state.basketW) / 2;
        if (scoreEl) scoreEl.textContent = '0';
        if (timeEl) timeEl.textContent = '30';
      };

      const spawnHeart = () => {
        const size = 18 + Math.random() * 18;
        state.hearts.push({
          x: Math.random() * (canvas.width - size),
          y: -size,
          size,
          color: palette[Math.floor(Math.random() * palette.length)],
          speed: 80 + Math.random() * 110 + state.score * 2,
          wobble: Math.random() * 6,
          wobbleRate: 2 + Math.random() * 3
        });
      };

      const finishGame = () => {
        state.running = false;

        let message = '甜度满分，再来一局？';
        if (state.score < 10) message = '继续挑战，下一局会更稳。';
        if (state.score >= 18) message = '太厉害了，几乎全接住了。';

        if (resultEl) resultEl.textContent = `${message} 本局得分 ${state.score}。`;
        if (startBtn) startBtn.textContent = '再玩一局';
      };

      const drawScene = () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        const grd = ctx.createLinearGradient(0, 0, 0, canvas.height);
        grd.addColorStop(0, '#fff5f8');
        grd.addColorStop(1, '#ffe1ea');
        ctx.fillStyle = grd;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        ctx.fillStyle = '#ffd6e1';
        ctx.fillRect(0, canvas.height - 70, canvas.width, 70);

        for (const heart of state.hearts) {
          drawHeart(heart.x, heart.y, heart.size, heart.color);
        }

        const basketY = canvas.height - state.basketH - 22;
        const basketGradient = ctx.createLinearGradient(state.basketX, basketY, state.basketX, basketY + state.basketH);
        basketGradient.addColorStop(0, '#ff7aa2');
        basketGradient.addColorStop(1, '#ff4d6d');
        ctx.fillStyle = basketGradient;
        ctx.beginPath();
        ctx.roundRect(state.basketX, basketY, state.basketW, state.basketH, 12);
        ctx.fill();

        ctx.fillStyle = '#ffffff';
        ctx.font = '14px "Noto Serif SC", serif';
        ctx.fillText('接住我 ❤', state.basketX + 12, basketY + 15);
      };

      const update = (dt) => {
        if (!state.running) {
          drawScene();
          return;
        }

        state.spawnClock += dt;
        state.secondClock += dt;

        const spawnEvery = Math.max(0.24, 0.7 - state.score * 0.01);
        if (state.spawnClock >= spawnEvery) {
          state.spawnClock = 0;
          spawnHeart();
        }

        const basketY = canvas.height - state.basketH - 22;

        state.hearts = state.hearts.filter((heart) => {
          heart.wobble += heart.wobbleRate * dt;
          heart.x += Math.sin(heart.wobble) * 28 * dt;
          heart.x = Math.max(0, Math.min(canvas.width - heart.size, heart.x));
          heart.y += heart.speed * dt;

          const hitX = heart.x + heart.size > state.basketX && heart.x < state.basketX + state.basketW;
          const hitY = heart.y + heart.size >= basketY && heart.y <= basketY + state.basketH;

          if (hitX && hitY) {
            state.score += 1;
            if (scoreEl) scoreEl.textContent = String(state.score);

            const rect = canvas.getBoundingClientRect();
            emitGameSpark(
              rect.left + (heart.x + heart.size / 2) / canvas.width * rect.width,
              rect.top + (heart.y + heart.size / 2) / canvas.height * rect.height,
              7
            );

            return false;
          }

          return heart.y < canvas.height + 26;
        });

        if (state.secondClock >= 1) {
          state.secondClock = 0;
          state.timeLeft -= 1;
          if (timeEl) timeEl.textContent = String(Math.max(state.timeLeft, 0));
          if (state.timeLeft <= 0) finishGame();
        }

        drawScene();
      };

      const loop = (ts) => {
        const dt = Math.min(0.033, (ts - state.lastTs) / 1000);
        state.lastTs = ts;
        update(dt);
        state.rafId = window.requestAnimationFrame(loop);
      };

      const moveBasket = (clientX) => {
        const rect = canvas.getBoundingClientRect();
        const x = ((clientX - rect.left) / rect.width) * canvas.width;
        state.basketX = Math.max(0, Math.min(canvas.width - state.basketW, x - state.basketW / 2));
      };

      canvas.addEventListener('mousemove', (event) => moveBasket(event.clientX));
      canvas.addEventListener('touchmove', (event) => {
        if (!event.touches[0]) return;
        moveBasket(event.touches[0].clientX);
      }, { passive: true });

      if (startBtn) {
        startBtn.addEventListener('click', () => {
          if (state.running) return;
          resetGame();
          state.running = true;
          if (resultEl) resultEl.textContent = '加油，接住更多爱心。';
          startBtn.textContent = '游戏进行中';
        });
      }

      resetGame();
      drawScene();
      state.rafId = window.requestAnimationFrame(loop);
      window.addEventListener('beforeunload', () => window.cancelAnimationFrame(state.rafId));
    })();
  </script>

