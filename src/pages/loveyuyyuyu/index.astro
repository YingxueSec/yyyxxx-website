---
import Layout from '../../layouts/Layout.astro';

const pageConfig = {
  partnerName: '晓玉',
  fromName: '宇宇',
  togetherSince: '2024-05-20',
  letterTitle: '给你的一封小信',
  letterBody:
    '谢谢你把平凡的每一天都点亮。你笑起来的时候，我会觉得整个世界都在放晴。以后也想继续和你一起看电影、散步、吃夜宵，把每个小日子过成值得纪念的大日子。',
  memories: [
    {
      title: '第一次见面',
      time: '2024.05',
      note: '那天你笑着说“你好”，我心里就已经偷偷按下了收藏键。'
    },
    {
      title: '一起看夜景',
      time: '2024.09',
      note: '风有点凉，但你把手塞到我掌心的那一秒，世界很暖。'
    },
    {
      title: '今年想实现',
      time: '2026',
      note: '一起去海边看日出，顺便把我们合照拍到 999 张。'
    }
  ]
};

const pageTitle = `给${pageConfig.partnerName}的小宇宙`;
const pageDescription = `在 /loveyuyyuyu/ 给 ${pageConfig.partnerName} 的专属页面，含互动小游戏与纪念时刻。`;
---

<Layout title={pageTitle} description={pageDescription} noindex={true}>
  <main
    class="love-root"
    data-since={pageConfig.togetherSince}
    data-partner={pageConfig.partnerName}
    data-from={pageConfig.fromName}
    data-letter-title={pageConfig.letterTitle}
    data-letter-body={pageConfig.letterBody}
  >
    <div class="aurora" aria-hidden="true">
      <span class="blob b1"></span>
      <span class="blob b2"></span>
      <span class="blob b3"></span>
    </div>
    <div class="cursor-glow" aria-hidden="true"></div>
    <div class="floating-hearts" aria-hidden="true"></div>
    <div class="sparkle-rain" aria-hidden="true"></div>

    <section class="hero panel reveal">
      <p class="eyebrow">/loveyuyyuyu/ · for {pageConfig.partnerName}</p>
      <h1 class="title">给 <span>{pageConfig.partnerName}</span> 的小宇宙</h1>
      <p class="subtitle">你负责可爱，我负责把每个普通日子都过成节日。</p>

      <div class="love-beat" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="timer-box" aria-live="polite">
        <p>我们已经并肩走过</p>
        <p id="together-counter" class="counter">加载中...</p>
      </div>

      <div class="hero-actions">
        <button id="open-letter" class="btn solid" type="button">展开小信封</button>
        <a class="btn ghost" href="#mini-game">开始爱心接接乐</a>
      </div>
    </section>

    <section id="letter-card" class="panel letter-card reveal" hidden>
      <h2 id="letter-title">{pageConfig.letterTitle}</h2>
      <p id="letter-body" data-raw={pageConfig.letterBody}>{pageConfig.letterBody}</p>
    </section>

    <section class="panel memories reveal">
      <h2>我们的小瞬间</h2>
      <div class="memory-grid">
        {pageConfig.memories.map((item, idx) => (
          <article class="memory-item" data-index={idx}>
            <p class="memory-time">{item.time}</p>
            <h3>{item.title}</h3>
            <p>{item.note}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="panel capsule reveal">
      <h2>今日甜度扭蛋</h2>
      <p id="capsule-result" class="capsule-result">点一下，抽一条今天的专属情话。</p>
      <button id="capsule-btn" class="btn solid" type="button">抽一条</button>
    </section>

    <section id="mini-game" class="panel game-panel reveal">
      <div>
        <h2>爱心接接乐</h2>
        <p>移动底部小篮子接住掉落的爱心，30 秒结束。鼠标和触摸都支持。</p>
      </div>

      <div class="game-status">
        <p>得分：<strong id="game-score">0</strong></p>
        <p>剩余：<strong id="game-time">30</strong>s</p>
      </div>

      <canvas id="heart-game" width="360" height="500" aria-label="爱心接接乐游戏画布"></canvas>

      <div class="game-actions">
        <button id="game-start" class="btn solid" type="button">开始游戏</button>
        <p id="game-result" class="game-result">准备好就开始吧。</p>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const root = document.querySelector('.love-root');
      if (!root) return;

      const counterEl = document.getElementById('together-counter');
      const letterCard = document.getElementById('letter-card');
      const letterBody = document.getElementById('letter-body');
      const openLetterBtn = document.getElementById('open-letter');
      const memories = Array.from(document.querySelectorAll('.memory-item'));
      const heartLayer = document.querySelector('.floating-hearts');
      const sparkleLayer = document.querySelector('.sparkle-rain');
      const cursorGlow = document.querySelector('.cursor-glow');
      const capsuleBtn = document.getElementById('capsule-btn');
      const capsuleResult = document.getElementById('capsule-result');
      const revealEls = Array.from(document.querySelectorAll('.reveal'));

      const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const sinceRaw = root.getAttribute('data-since') || '2024-05-20';
      const sinceDate = new Date(sinceRaw + 'T00:00:00+08:00');
      const letterRaw = letterBody?.getAttribute('data-raw') || letterBody?.textContent || '';

      const pad = (num) => String(num).padStart(2, '0');
      const updateCounter = () => {
        const now = new Date();
        const diff = Math.max(0, now.getTime() - sinceDate.getTime());

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
        const minutes = Math.floor((diff / (1000 * 60)) % 60);
        const seconds = Math.floor((diff / 1000) % 60);

        if (counterEl) {
          counterEl.textContent = `${days} 天 ${pad(hours)} 小时 ${pad(minutes)} 分 ${pad(seconds)} 秒`;
        }
      };

      updateCounter();
      window.setInterval(updateCounter, 1000);

      const revealAll = () => revealEls.forEach((el, idx) => {
        window.setTimeout(() => el.classList.add('is-visible'), idx * 90);
      });

      if (!prefersReduce && 'IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.2 });
        revealEls.forEach((el) => observer.observe(el));
      } else {
        revealAll();
      }

      let typingTimer = 0;
      const typeLetter = () => {
        if (!letterBody) return;
        if (prefersReduce) {
          letterBody.textContent = letterRaw;
          return;
        }
        if (typingTimer) {
          window.clearTimeout(typingTimer);
          typingTimer = 0;
        }

        let cursor = 0;
        letterBody.textContent = '';

        const step = () => {
          cursor += 1 + Math.floor(Math.random() * 2);
          letterBody.textContent = letterRaw.slice(0, cursor);
          if (cursor < letterRaw.length) {
            typingTimer = window.setTimeout(step, 22 + Math.random() * 48);
          }
        };

        step();
      };

      const burstHearts = (x, y, count = 14) => {
        if (!heartLayer) return;

        for (let i = 0; i < count; i += 1) {
          const heart = document.createElement('span');
          heart.className = 'burst-heart';
          const angle = (Math.PI * 2 * i) / count;
          const distance = 26 + Math.random() * 88;
          heart.style.setProperty('--tx', `${Math.cos(angle) * distance}px`);
          heart.style.setProperty('--ty', `${Math.sin(angle) * distance}px`);
          heart.style.left = `${x}px`;
          heart.style.top = `${y}px`;
          heart.textContent = Math.random() > 0.5 ? '❤' : '💗';
          heartLayer.appendChild(heart);
          window.setTimeout(() => heart.remove(), 1300);
        }
      };

      const emitGameSpark = (x, y, count = 8) => {
        if (!heartLayer) return;

        for (let i = 0; i < count; i += 1) {
          const spark = document.createElement('span');
          spark.className = 'game-spark';
          spark.style.left = `${x}px`;
          spark.style.top = `${y}px`;
          spark.style.setProperty('--vx', `${(Math.random() - 0.5) * 120}px`);
          spark.style.setProperty('--vy', `${-30 - Math.random() * 90}px`);
          spark.style.setProperty('--scale', `${0.6 + Math.random() * 0.8}`);
          heartLayer.appendChild(spark);
          window.setTimeout(() => spark.remove(), 800);
        }
      };

      if (openLetterBtn && letterCard) {
        openLetterBtn.addEventListener('click', (event) => {
          const willOpen = letterCard.hasAttribute('hidden');

          if (willOpen) {
            letterCard.removeAttribute('hidden');
            letterCard.classList.add('show');
            openLetterBtn.textContent = '收起小信封';
            typeLetter();

            const rect = event.currentTarget.getBoundingClientRect();
            burstHearts(rect.left + rect.width / 2, rect.top + rect.height / 2, 18);
          } else {
            letterCard.setAttribute('hidden', '');
            letterCard.classList.remove('show');
            openLetterBtn.textContent = '展开小信封';
            if (letterBody) letterBody.textContent = letterRaw;
          }
        });
      }

      memories.forEach((card, idx) => {
        card.style.setProperty('--delay', `${idx * 110}ms`);

        card.addEventListener('pointermove', (event) => {
          if (prefersReduce) return;
          const rect = card.getBoundingClientRect();
          const px = ((event.clientX - rect.left) / rect.width) - 0.5;
          const py = ((event.clientY - rect.top) / rect.height) - 0.5;
          card.style.setProperty('--rx', `${(-py * 7).toFixed(2)}deg`);
          card.style.setProperty('--ry', `${(px * 9).toFixed(2)}deg`);
        });

        card.addEventListener('pointerleave', () => {
          card.style.setProperty('--rx', '0deg');
          card.style.setProperty('--ry', '0deg');
        });

        card.addEventListener('click', (event) => {
          const rect = event.currentTarget.getBoundingClientRect();
          burstHearts(rect.left + rect.width / 2, rect.top + rect.height / 2, 10);
          card.classList.add('pop');
          window.setTimeout(() => card.classList.remove('pop'), 260);
        });
      });

      if (heartLayer) {
        const heartCount = window.innerWidth < 600 ? 18 : 34;
        for (let i = 0; i < heartCount; i += 1) {
          const floatHeart = document.createElement('span');
          floatHeart.className = 'float-heart';
          floatHeart.textContent = Math.random() > 0.5 ? '❤' : '♡';
          floatHeart.style.left = `${Math.random() * 100}%`;
          floatHeart.style.animationDelay = `${Math.random() * 10}s`;
          floatHeart.style.animationDuration = `${9 + Math.random() * 12}s`;
          heartLayer.appendChild(floatHeart);
        }
      }

      if (sparkleLayer && !prefersReduce) {
        const sparkleCount = window.innerWidth < 600 ? 24 : 45;
        for (let i = 0; i < sparkleCount; i += 1) {
          const star = document.createElement('span');
          star.className = 'star';
          star.style.left = `${Math.random() * 100}%`;
          star.style.top = `${Math.random() * 100}%`;
          star.style.animationDelay = `${Math.random() * 6}s`;
          star.style.animationDuration = `${2.2 + Math.random() * 3.8}s`;
          sparkleLayer.appendChild(star);
        }
      }

      const capsuleLines = [
        '今天也想把“我喜欢你”说上 100 遍。',
        '你一个眼神，就能把我一天的坏情绪清空。',
        '和你分享琐碎日常，是我最上头的浪漫。',
        '如果快乐有名字，那一定有你。',
        '今天也请继续做我的宇宙第一可爱。',
        '你出现以后，连风都在给我递糖。'
      ];

      if (capsuleBtn && capsuleResult) {
        capsuleBtn.addEventListener('click', (event) => {
          const line = capsuleLines[Math.floor(Math.random() * capsuleLines.length)];
          capsuleResult.textContent = line;
          capsuleResult.classList.remove('flash');
          void capsuleResult.offsetWidth;
          capsuleResult.classList.add('flash');

          const rect = event.currentTarget.getBoundingClientRect();
          burstHearts(rect.left + rect.width / 2, rect.top + rect.height / 2, 16);
        });
      }

      if (cursorGlow && !prefersReduce) {
        window.addEventListener('pointermove', (event) => {
          cursorGlow.style.left = `${event.clientX}px`;
          cursorGlow.style.top = `${event.clientY}px`;
          cursorGlow.style.opacity = '1';
        });

        window.addEventListener('pointerdown', () => {
          cursorGlow.classList.add('active');
          window.setTimeout(() => cursorGlow.classList.remove('active'), 180);
        });
      }

      const canvas = document.getElementById('heart-game');
      const scoreEl = document.getElementById('game-score');
      const timeEl = document.getElementById('game-time');
      const startBtn = document.getElementById('game-start');
      const resultEl = document.getElementById('game-result');

      if (!(canvas instanceof HTMLCanvasElement)) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const state = {
        running: false,
        score: 0,
        timeLeft: 30,
        basketX: 140,
        basketW: 86,
        basketH: 22,
        hearts: [],
        spawnClock: 0,
        secondClock: 0,
        lastTs: performance.now(),
        rafId: 0
      };

      const palette = ['#ff6b8a', '#ff8fab', '#ff4d6d', '#ffc2d1'];

      const drawHeart = (x, y, size, color) => {
        ctx.save();
        ctx.translate(x, y);
        ctx.scale(size / 20, size / 20);
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.moveTo(10, 18);
        ctx.bezierCurveTo(10, 18, 1, 12, 1, 7.5);
        ctx.bezierCurveTo(1, 4, 3.5, 1, 7, 1);
        ctx.bezierCurveTo(9, 1, 10, 2.2, 10, 2.2);
        ctx.bezierCurveTo(10, 2.2, 11, 1, 13, 1);
        ctx.bezierCurveTo(16.5, 1, 19, 4, 19, 7.5);
        ctx.bezierCurveTo(19, 12, 10, 18, 10, 18);
        ctx.fill();
        ctx.restore();
      };

      const resetGame = () => {
        state.score = 0;
        state.timeLeft = 30;
        state.hearts = [];
        state.spawnClock = 0;
        state.secondClock = 0;
        state.basketX = (canvas.width - state.basketW) / 2;
        if (scoreEl) scoreEl.textContent = '0';
        if (timeEl) timeEl.textContent = '30';
      };

      const spawnHeart = () => {
        const size = 18 + Math.random() * 18;
        state.hearts.push({
          x: Math.random() * (canvas.width - size),
          y: -size,
          size,
          color: palette[Math.floor(Math.random() * palette.length)],
          speed: 80 + Math.random() * 110 + state.score * 2,
          wobble: Math.random() * 6,
          wobbleRate: 2 + Math.random() * 3
        });
      };

      const finishGame = () => {
        state.running = false;

        let message = '你的可爱值已经满分，继续冲一次？';
        if (state.score < 10) message = '你是慢热型甜妹，再来一局我相信你会更高分。';
        if (state.score >= 18) message = '太强了！你把爱心全都稳稳接住了。';

        if (resultEl) resultEl.textContent = `${message} 本局得分 ${state.score}。`;
        if (startBtn) startBtn.textContent = '再玩一局';
      };

      const drawScene = () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        const grd = ctx.createLinearGradient(0, 0, 0, canvas.height);
        grd.addColorStop(0, '#fff5f8');
        grd.addColorStop(1, '#ffe1ea');
        ctx.fillStyle = grd;
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        ctx.fillStyle = '#ffd6e1';
        ctx.fillRect(0, canvas.height - 70, canvas.width, 70);

        for (const heart of state.hearts) {
          drawHeart(heart.x, heart.y, heart.size, heart.color);
        }

        const basketY = canvas.height - state.basketH - 22;
        const basketGradient = ctx.createLinearGradient(state.basketX, basketY, state.basketX, basketY + state.basketH);
        basketGradient.addColorStop(0, '#ff7aa2');
        basketGradient.addColorStop(1, '#ff4d6d');
        ctx.fillStyle = basketGradient;
        ctx.beginPath();
        ctx.roundRect(state.basketX, basketY, state.basketW, state.basketH, 12);
        ctx.fill();

        ctx.fillStyle = '#ffffff';
        ctx.font = '14px "Noto Serif SC", serif';
        ctx.fillText('接住我 ❤', state.basketX + 12, basketY + 15);
      };

      const update = (dt) => {
        if (!state.running) {
          drawScene();
          return;
        }

        state.spawnClock += dt;
        state.secondClock += dt;

        const spawnEvery = Math.max(0.24, 0.7 - state.score * 0.01);
        if (state.spawnClock >= spawnEvery) {
          state.spawnClock = 0;
          spawnHeart();
        }

        const basketY = canvas.height - state.basketH - 22;

        state.hearts = state.hearts.filter((heart) => {
          heart.wobble += heart.wobbleRate * dt;
          heart.x += Math.sin(heart.wobble) * 28 * dt;
          heart.x = Math.max(0, Math.min(canvas.width - heart.size, heart.x));
          heart.y += heart.speed * dt;

          const hitX = heart.x + heart.size > state.basketX && heart.x < state.basketX + state.basketW;
          const hitY = heart.y + heart.size >= basketY && heart.y <= basketY + state.basketH;

          if (hitX && hitY) {
            state.score += 1;
            if (scoreEl) scoreEl.textContent = String(state.score);

            const rect = canvas.getBoundingClientRect();
            emitGameSpark(
              rect.left + (heart.x + heart.size / 2) / canvas.width * rect.width,
              rect.top + (heart.y + heart.size / 2) / canvas.height * rect.height,
              7
            );

            return false;
          }

          return heart.y < canvas.height + 26;
        });

        if (state.secondClock >= 1) {
          state.secondClock = 0;
          state.timeLeft -= 1;
          if (timeEl) timeEl.textContent = String(Math.max(state.timeLeft, 0));
          if (state.timeLeft <= 0) finishGame();
        }

        drawScene();
      };

      const loop = (ts) => {
        const dt = Math.min(0.033, (ts - state.lastTs) / 1000);
        state.lastTs = ts;
        update(dt);
        state.rafId = window.requestAnimationFrame(loop);
      };

      const moveBasket = (clientX) => {
        const rect = canvas.getBoundingClientRect();
        const x = ((clientX - rect.left) / rect.width) * canvas.width;
        state.basketX = Math.max(0, Math.min(canvas.width - state.basketW, x - state.basketW / 2));
      };

      canvas.addEventListener('mousemove', (event) => moveBasket(event.clientX));
      canvas.addEventListener('touchmove', (event) => {
        if (!event.touches[0]) return;
        moveBasket(event.touches[0].clientX);
      }, { passive: true });

      if (startBtn) {
        startBtn.addEventListener('click', () => {
          if (state.running) return;
          resetGame();
          state.running = true;
          if (resultEl) resultEl.textContent = '加油，接住更多爱心！';
          startBtn.textContent = '游戏进行中';
        });
      }

      resetGame();
      drawScene();
      state.rafId = window.requestAnimationFrame(loop);
      window.addEventListener('beforeunload', () => window.cancelAnimationFrame(state.rafId));
    })();
  </script>

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Zhi+Mang+Xing&display=swap');

    .love-root {
      --bg-1: #fff7f2;
      --bg-2: #ffe2ea;
      --ink: #59283c;
      --rose: #ff4d6d;
      --rose-soft: #ff8fab;
      --cream: #fffaf5;
      min-height: 100vh;
      padding: 2.2rem 1rem 4rem;
      background:
        radial-gradient(circle at 10% 10%, rgba(255, 255, 255, 0.75), transparent 45%),
        radial-gradient(circle at 90% 0%, rgba(255, 143, 171, 0.24), transparent 40%),
        linear-gradient(160deg, var(--bg-1), var(--bg-2));
      color: var(--ink);
      font-family: 'Noto Serif SC', 'STSong', serif;
      position: relative;
      overflow: hidden;
      isolation: isolate;
    }

    .aurora {
      position: fixed;
      inset: -20vh -12vw;
      pointer-events: none;
      z-index: 0;
      filter: blur(28px);
      opacity: 0.6;
    }

    .blob {
      position: absolute;
      border-radius: 50%;
      mix-blend-mode: screen;
      animation: blob-float 18s ease-in-out infinite;
    }

    .blob.b1 {
      width: 44vw;
      height: 44vw;
      min-width: 220px;
      min-height: 220px;
      background: radial-gradient(circle, rgba(255, 130, 176, 0.48), transparent 66%);
      left: 0;
      top: 4%;
    }

    .blob.b2 {
      width: 48vw;
      height: 48vw;
      min-width: 260px;
      min-height: 260px;
      background: radial-gradient(circle, rgba(255, 190, 214, 0.52), transparent 72%);
      right: 4%;
      top: 0;
      animation-delay: -6s;
    }

    .blob.b3 {
      width: 52vw;
      height: 52vw;
      min-width: 280px;
      min-height: 280px;
      background: radial-gradient(circle, rgba(255, 107, 138, 0.35), transparent 68%);
      left: 28%;
      bottom: -10%;
      animation-delay: -12s;
    }

    .cursor-glow {
      position: fixed;
      width: 220px;
      height: 220px;
      border-radius: 50%;
      pointer-events: none;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, rgba(255, 103, 145, 0.3), rgba(255, 103, 145, 0.08) 45%, transparent 70%);
      filter: blur(8px);
      opacity: 0;
      z-index: 0;
      transition: transform 0.15s ease, opacity 0.25s ease;
    }

    .cursor-glow.active {
      transform: translate(-50%, -50%) scale(0.86);
    }

    .floating-hearts,
    .sparkle-rain {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .float-heart {
      position: absolute;
      bottom: -40px;
      color: rgba(255, 77, 109, 0.24);
      font-size: 1rem;
      animation-name: drift-up;
      animation-timing-function: linear;
      animation-iteration-count: infinite;
    }

    .star {
      position: absolute;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.9);
      box-shadow: 0 0 8px rgba(255, 255, 255, 0.8);
      animation: twinkle ease-in-out infinite;
    }

    .star:nth-child(3n) {
      width: 3px;
      height: 3px;
      background: rgba(255, 220, 230, 0.9);
    }

    .panel {
      width: min(920px, 100%);
      margin: 0 auto 1rem;
      position: relative;
      z-index: 1;
      background: rgba(255, 255, 255, 0.74);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 164, 188, 0.58);
      border-radius: 24px;
